# Copy to .env.local and fill in. .env.local is gitignored.
EBAY_ENV=sandbox

# Sandbox application keyset (eBay Developer Portal > Application Keys)
EBAY_CLIENT_ID=
EBAY_CLIENT_SECRET=
EBAY_RU_NAME=

# Per-seller refresh token, obtained via /api/ebay/auth/login -> consent -> callback
EBAY_REFRESH_TOKEN=
