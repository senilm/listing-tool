# Copy to .env.local and fill in. .env.local is gitignored.

# Database — Neon serverless Postgres pooled connection string (postgresql://...)
DATABASE_URL=

# Better Auth — secret signs sessions; generate with: npx @better-auth/cli secret
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000

EBAY_ENV=sandbox

# Sandbox application keyset (eBay Developer Portal > Application Keys)
EBAY_CLIENT_ID=
EBAY_CLIENT_SECRET=
EBAY_RU_NAME=

# Per-seller refresh token, obtained via /api/ebay/auth/login -> consent -> callback
EBAY_REFRESH_TOKEN=
