# Copy to .env.local and fill in. .env.local is gitignored.

# Database — Neon serverless Postgres pooled connection string (postgresql://...)
DATABASE_URL=

# Better Auth — secret signs sessions; generate with: npx @better-auth/cli secret
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000

EBAY_ENV=sandbox

# Sandbox application keyset (eBay Developer Portal > Application Keys).
# The RuName's "Auth accepted URL" must point at /api/ebay/accounts/callback.
EBAY_CLIENT_ID=
EBAY_CLIENT_SECRET=
EBAY_RU_NAME=

# Encrypts per-account eBay refresh tokens at rest (AES-256-GCM).
# Generate with: openssl rand -hex 32
EBAY_TOKEN_ENCRYPTION_KEY=
