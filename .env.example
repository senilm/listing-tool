# Copy to .env.local and fill in. .env.local is gitignored.

# Database — Neon serverless Postgres pooled connection string (postgresql://...)
DATABASE_URL=

# Better Auth — secret signs sessions; generate with: npx @better-auth/cli secret
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000

# Public support/contact email shown on the privacy policy page.
NEXT_PUBLIC_SUPPORT_EMAIL=

EBAY_ENV=sandbox

# Sandbox application keyset (eBay Developer Portal > Application Keys).
# The RuName's "Auth accepted URL" must point at /api/ebay/accounts/callback.
EBAY_CLIENT_ID=
EBAY_CLIENT_SECRET=
EBAY_RU_NAME=

# Encrypts per-account eBay refresh tokens at rest (AES-256-GCM).
# Generate with: openssl rand -hex 32
EBAY_TOKEN_ENCRYPTION_KEY=

# Vercel Blob — product image storage. Auto-injected on Vercel once the Blob
# store is linked; set it locally (Storage > your store > .env.local) for dev.
BLOB_READ_WRITE_TOKEN=

# Protects the daily blob-cleanup cron route. Vercel Cron sends it as a bearer
# token. Generate with: openssl rand -hex 32
CRON_SECRET=

# --- eBay Marketplace Account Deletion notification ---
# Token we invent (32-80 chars, [A-Za-z0-9_-]); generate with: openssl rand -hex 24.
# Paste the SAME value into the eBay Developer Portal. Endpoint URL must match the
# registered URL exactly (use a tunnel HTTPS URL for local dev).
EBAY_DELETION_VERIFICATION_TOKEN=
EBAY_DELETION_ENDPOINT_URL=
